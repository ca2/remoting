                                    <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                                    <font key="font" metaFont="system"/>
                                </buttonCell>
                            </button>
                            <box identifier="IDD_CONFIG_PORT_MAPPING_PAGE.IDC_STATIC.ctl-0228" fixedFrame="YES" title="Help" translatesAutoresizingMaskIntoConstraints="NO" id="ctl-0228" userLabel="IDC_STATIC">
                                <rect key="frame" x="10" y="9" width="483" height="194"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                                <view key="contentView" id="box-0230">
                                    <rect key="frame" x="0.0" y="0.0" width="483" height="182"/>
                                    <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                                </view>
                            </box>
                            <textField identifier="IDD_CONFIG_PORT_MAPPING_PAGE.IDC_STATIC.ctl-0231" focusRingType="none" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="ctl-0231" userLabel="IDC_STATIC">
                                <rect key="frame" x="26" y="135" width="452" height="44"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                                <textFieldCell key="cell" id="cell-0232">
                                    <font key="font" metaFont="system"/>
                                    <string key="title">By default, Remoting Node listens for incoming connections on just one main TCP port, and shows the complete desktop to its clients.</string>
                                    <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                    <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                                </textFieldCell>
                            </textField>
                            <textField identifier="IDD_CONFIG_PORT_MAPPING_PAGE.IDC_STATIC.ctl-0233" focusRingType="none" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="ctl-0233" userLabel="IDC_STATIC">
                                <rect key="frame" x="26" y="76" width="452" height="59"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                                <textFieldCell key="cell" id="cell-0234">
                                    <font key="font" metaFont="system"/>
                                    <string key="title">However, it's possible to make it listen on a number of extra ports, where each port has a specific area of the screen associated with it. If a client then connects to an extra port, only that part of the screen will be shown.</string>
                                    <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                    <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                                </textFieldCell>
                            </textField>
                            <textField identifier="IDD_CONFIG_PORT_MAPPING_PAGE.IDC_STATIC.ctl-0235" focusRingType="none" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="ctl-0235" userLabel="IDC_STATIC">
                                <rect key="frame" x="26" y="32" width="452" height="44"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                                <textFieldCell key="cell" id="cell-0236">
                                    <font key="font" metaFont="system"/>
                                    <string key="title">Screen areas are represented by patterns like 640x480+120+240 (in this example, width is 640, height is 480, horizontal offset is 120 and vertical offset is 240 pixels).</string>
                                    <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                    <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                                </textFieldCell>
                            </textField>
                        </subviews>
                    </view>
                </viewController>
                <customObject id="responder-0208" userLabel="First Responder" customClass="NSResponder" sceneMemberID="firstResponder"/>
            </objects>
