                                <textFieldCell key="cell" id="cell-0498">
                                    <font key="font" metaFont="system"/>
                                    <string key="title">To specify a TCP port, append it after two colons (myhost::443).  A number up to 99 after just one colon specifies an offset from the default port 5500.</string>
